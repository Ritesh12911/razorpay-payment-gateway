# ═══════════════════════════════════════════════════
# RAZORPAY GATEWAY — Environment Configuration
# ═══════════════════════════════════════════════════

# Razorpay API Keys
# Test keys: rzp_test_xxx / Live keys: rzp_live_xxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook Secret (from Dashboard → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Server
PORT=3000
NODE_ENV=production

# CORS — Your hosted domain (no trailing slash)
ALLOWED_ORIGIN=https://yourdomain.com
